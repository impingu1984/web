---
// src/pages/blog/index.astro
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import BlogList from '../../components/BlogList.astro';
import { getCollection } from 'astro:content';

const includeDrafts = import.meta.env.INCLUDE_CONTENT_DRAFTS === 'true';

const allPosts = await getCollection('blogs', ({ data }) => {
  return includeDrafts ? true : !data.draft;
});

const posts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base
  title="Writing — Iain Morton"
  description="Long-form and short-form writing on engineering leadership, cloud infrastructure, data platform, and building high-performing teams."
>
  <Nav />

  <main id="main-content" class="pt-20">
    <section class="py-24 md:py-32 px-6 md:px-12 lg:px-24" aria-labelledby="blog-heading">
      <div class="max-w-4xl mx-auto">

        <p class="reveal font-mono text-accent text-sm mb-3 tracking-widest uppercase">
          Writing
        </p>

        <h1
          id="blog-heading"
          class="reveal reveal-delay-1 font-display text-3xl md:text-5xl font-bold text-text mb-12"
        >
          All Posts
        </h1>

        <div class="reveal reveal-delay-2 w-16 h-px bg-accent mb-16"></div>

        {posts.length === 0 ? (
          <p class="font-mono text-text-muted text-sm">No posts published yet. Check back soon.</p>
        ) : (
          <BlogList posts={posts} />
        )}

      </div>
    </section>
  </main>
</Base>