---
// src/layouts/Base.astro
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/fraunces/400.css';
import '@fontsource/fraunces/700.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Iain Morton — Head of Engineering · CTO',
  description = 'Senior engineering leader with 15+ years of experience in cloud infrastructure, data platform, and high-performing team building.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://iainmorton.me" />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-background text-text font-body antialiased">
    <slot />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  /* Tailwind v4 — CSS-first configuration */
  @import "tailwindcss";

  @theme {
    /* Colours */
    --color-background: #0a0e13;
    --color-surface: #111820;
    --color-surface-alt: #1a2230;
    --color-accent: #00d4ff;
    --color-accent-dim: #00a8cc;
    --color-text: #e2e8f0;
    --color-text-muted: #8899aa;
    --color-border: #1e2d3d;

    /* Font families */
    --font-mono: "JetBrains Mono", monospace;
    --font-display: "Fraunces", serif;
    --font-body: "JetBrains Mono", monospace;

    /* Animations */
    --animate-fade-up: fadeUp 0.6s ease forwards;
    --animate-fade-in: fadeIn 0.5s ease forwards;
    --animate-blink: blink 1s step-end infinite;

    /* Keyframes */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }
  }

  /* CSS custom properties for use outside Tailwind utilities */
  :root {
    --color-accent: #00d4ff;
    --color-accent-dim: #00a8cc;
    --color-bg: #0a0e13;
    --color-surface: #111820;
    --color-surface-alt: #1a2230;
    --color-text: #e2e8f0;
    --color-text-muted: #8899aa;
    --color-border: #1e2d3d;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.08s; }
  .reveal-delay-2 { transition-delay: 0.16s; }
  .reveal-delay-3 { transition-delay: 0.24s; }
  .reveal-delay-4 { transition-delay: 0.32s; }
  .reveal-delay-5 { transition-delay: 0.40s; }

  /* Terminal cursor blink */
  .cursor::after {
    content: '█';
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  /* Smooth scrollbar */
  html {
    scrollbar-color: var(--color-border) var(--color-bg);
    scrollbar-width: thin;
  }

  /* Replaces inline style="" attributes — keeps CSP clean */
  .nav-backdrop {
    background: rgba(10, 14, 19, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(30, 45, 61, 0.6);
  }
  .nav-mobile-dropdown {
    background: rgba(10, 14, 19, 0.97);
    border-bottom: 1px solid #1e2d3d;
  }
  .hero-glow {
    background: radial-gradient(circle, #00d4ff 0%, transparent 70%);
  }
</style>