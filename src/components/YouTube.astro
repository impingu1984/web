---
// src/components/YouTube.astro
interface Props {
  id: string;
  title: string;
}
const { id, title } = Astro.props;
---

<div class="youtube-embed">
  <iframe
    src={`https://www.youtube.com/embed/${id}`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
    aria-label={title}
  ></iframe>
</div>

<style>
  .youtube-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    margin: 2rem 0;
    border-radius: 4px;
    overflow: hidden;
  }
  .youtube-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>