---
// src/components/BlogCard.astro
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  readingTime: number;
}
const { title, description, date, tags, slug, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class="blog-card group p-6 border border-border rounded-sm bg-surface-alt hover:border-accent transition-colors duration-300">
  <header class="mb-3">
    <div class="flex items-center gap-3 mb-2">
      <time
        datetime={date.toISOString()}
        class="font-mono text-xs text-text-muted"
      >
        {formattedDate}
      </time>
      <span class="text-border font-mono text-xs">·</span>
      <span class="font-mono text-xs text-text-muted">{readingTime} min read</span>
    </div>
    <h3 class="font-display text-lg font-bold text-text group-hover:text-accent transition-colors duration-200 leading-snug">
      <a href={`/blog/${slug}`} class="focus:outline-none focus:ring-2 focus:ring-accent rounded-sm">
        {title}
      </a>
    </h3>
  </header>

  <p class="font-mono text-sm text-text-muted leading-relaxed mb-4 line-clamp-2">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4" role="list" aria-label="Tags">
      {tags.map(tag => (
        <span
          class="font-mono text-xs text-text-muted border border-border rounded-sm px-2 py-0.5 hover:border-accent hover:text-accent transition-colors duration-200"
          role="listitem"
        >
          {tag}
        </span>
      ))}
    </div>
  )}

  <a
    href={`/blog/${slug}`}
    class="font-mono text-xs text-accent hover:text-accent-dim transition-colors duration-200 inline-flex items-center gap-1 focus:outline-none focus:ring-2 focus:ring-accent rounded-sm"
    aria-label={`Read ${title}`}
  >
    Read →
  </a>
</article>