---
// src/components/TableOfContents.astro
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;

// Only include h2 and h3
const filtered = headings.filter(h => h.depth === 2 || h.depth === 3);

// Build tree: h2s are folders, h3s nest under the preceding h2
type TreeNode = { heading: Heading; children: Heading[] };
const tree: TreeNode[] = [];
for (const h of filtered) {
  if (h.depth === 2) {
    tree.push({ heading: h, children: [] });
  } else if (tree.length > 0) {
    tree[tree.length - 1].children.push(h);
  }
}
---

{filtered.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <p class="toc-label">~/post</p>

    <!-- Mobile toggle -->
    <details class="toc-mobile">
      <summary class="toc-summary">
        <span>on this page</span>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <ul class="toc-tree">
        {tree.map((node, i) => {
          const isLast = i === tree.length - 1;
          return (
            <li>
              <a href={`#${node.heading.slug}`} class="toc-item">
                <span class="toc-branch">{isLast && node.children.length === 0 ? '└──' : '├──'}</span>
                <!-- Folder icon -->
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                <span class="toc-text">{node.heading.text}</span>
              </a>
              {node.children.length > 0 && (
                <ul class="toc-children">
                  {node.children.map((child, ci) => {
                    const childLast = ci === node.children.length - 1;
                    return (
                      <li>
                        <a href={`#${child.slug}`} class="toc-item toc-child">
                          <span class="toc-branch">{childLast ? '└──' : '├──'}</span>
                          <!-- File icon -->
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                          <span class="toc-text">{child.text}</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </li>
          );
        })}
      </ul>
    </details>

    <!-- Desktop tree (always visible) -->
    <ul class="toc-tree toc-desktop">
      {tree.map((node, i) => {
        const isLast = i === tree.length - 1;
        return (
          <li>
            <a href={`#${node.heading.slug}`} class="toc-item" data-slug={node.heading.slug}>
              <span class="toc-branch">{isLast && node.children.length === 0 ? '└──' : '├──'}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              <span class="toc-text">{node.heading.text}</span>
            </a>
            {node.children.length > 0 && (
              <ul class="toc-children">
                {node.children.map((child, ci) => {
                  const childLast = ci === node.children.length - 1;
                  return (
                    <li>
                      <a href={`#${child.slug}`} class="toc-item toc-child" data-slug={child.slug}>
                        <span class="toc-branch">{childLast ? '└──' : '├──'}</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        <span class="toc-text">{child.text}</span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </li>
        );
      })}
    </ul>
  </nav>
)}

<style>
  .toc {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
  }
  .toc-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted, #8899aa);
    margin: 0 0 0.75rem;
  }
  .toc-tree {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .toc-children {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1.25rem;
  }
  .toc-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    line-height: 1.8;
    color: var(--color-text-muted, #8899aa);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .toc-item:hover,
  .toc-item.active {
    color: var(--color-accent);
  }
  .toc-branch {
    color: var(--color-text-muted, #8899aa);
    flex-shrink: 0;
  }
  .toc-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Mobile — show details/summary, hide desktop tree */
  .toc-desktop { display: none; }
  .toc-mobile { display: block; }
  .toc-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--color-text-muted, #8899aa);
    list-style: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border, #1e2d3d);
    margin-bottom: 0.5rem;
  }
  .toc-summary::-webkit-details-marker { display: none; }
  .toc-mobile .toc-tree { padding-top: 0.25rem; }

  /* Desktop — hide accordion, show tree */
  @media (min-width: 768px) {
    .toc-desktop { display: block; }
    .toc-mobile { display: none; }
  }
</style>

<script>
  // Highlight active TOC item based on scroll position
  const items = document.querySelectorAll('.toc-desktop .toc-item[data-slug]');
  if (items.length > 0) {
    const headingEls = Array.from(items).map(item => {
      const slug = item.getAttribute('data-slug');
      return slug ? document.getElementById(slug) : null;
    }).filter(Boolean) as HTMLElement[];

    const onScroll = () => {
      let active = headingEls[0];
      for (const el of headingEls) {
        if (el.getBoundingClientRect().top <= 120) active = el;
      }
      items.forEach(item => {
        item.classList.toggle('active', item.getAttribute('data-slug') === active?.id);
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>