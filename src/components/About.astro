---
// src/components/About.astro
import { about } from '../data/cv';
---

<section
  id="about"
  class="py-24 md:py-32 px-6 md:px-12 lg:px-24"
  aria-labelledby="about-heading"
>
  <div class="max-w-4xl mx-auto">
    <!-- Section label -->
    <p class="reveal font-mono text-accent text-sm mb-3 tracking-widest uppercase">
      01 / Profile
    </p>

    <h2
      id="about-heading"
      class="reveal reveal-delay-1 font-display text-3xl md:text-5xl font-bold text-text mb-12"
    >
      About Me
    </h2>

    <!-- Decorative accent bar -->
    <div class="reveal reveal-delay-2 w-16 h-px bg-accent mb-12"></div>

    <div class="space-y-6">
      {about.paragraphs.map((para, i) => (
        <p
          class={`reveal reveal-delay-${Math.min(i + 2, 5)} text-text-muted text-base md:text-lg leading-relaxed`}
        >
          {para}
        </p>
      ))}
    </div>
  </div>
</section>
