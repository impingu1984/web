---
// src/components/Nav.astro
import { meta } from '../data/cv';

const navLinks = [
  { href: '#about', label: 'Profile' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
];
---

<nav
  class="nav-backdrop fixed top-0 left-0 right-0 z-50 px-6 md:px-12 lg:px-24 py-4 flex items-center justify-between"
  aria-label="Primary navigation"
>
  <!-- Wordmark -->
  <a
    href="#hero"
    class="font-mono text-accent text-sm font-bold tracking-widest hover:text-text transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-accent rounded-sm"
    aria-label="Back to top"
  >
    IM<span class="text-text-muted">.me</span>
  </a>

  <!-- Desktop links -->
  <ul class="hidden md:flex items-center gap-8" role="list">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class="font-mono text-text-muted text-xs tracking-wider hover:text-accent transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-accent rounded-sm"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- LinkedIn CTA (desktop) -->
  <a
    href={meta.linkedin}
    target="_blank"
    rel="noopener noreferrer"
    class="hidden md:inline-flex items-center gap-2 px-4 py-2 border border-accent text-accent font-mono text-xs font-bold rounded-sm hover:bg-accent hover:text-background transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-background"
    aria-label="Connect on LinkedIn (opens in new tab)"
  >
    LinkedIn ↗
  </a>

  <!-- Mobile: hamburger toggle (CSS-only, no JS) -->
  <label
    for="mobile-nav-toggle"
    class="md:hidden cursor-pointer text-text-muted hover:text-accent transition-colors"
    aria-label="Toggle navigation menu"
  >
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
      <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </label>

  <input type="checkbox" id="mobile-nav-toggle" class="sr-only peer md:hidden" aria-label="Toggle navigation menu" />

  <!-- Mobile dropdown -->
  <div
    class="nav-mobile-dropdown absolute top-full left-0 right-0 hidden peer-checked:flex flex-col gap-0 md:hidden"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="font-mono text-text-muted text-sm px-6 py-4 border-b border-border hover:text-accent hover:bg-surface transition-colors duration-200"
      >
        {link.label}
      </a>
    ))}
    <a
      href={meta.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-accent text-sm px-6 py-4 hover:bg-surface transition-colors duration-200"
      aria-label="Connect on LinkedIn (opens in new tab)"
    >
      LinkedIn ↗
    </a>
  </div>
</nav>